# Copy this file to .env and adjust the values.
# Never commit .env to version control.

# ---------- PostgreSQL ----------
# REQUIRED: Set secure credentials for the database.
POSTGRES_USER=echogtfs
POSTGRES_PASSWORD=
POSTGRES_DB=echogtfs

# Change this if you want to mount the PostgreSQL data for permanent storage
# POSTGRES_MOUNT=/var/echogtfs

# ---------- Backend ----------
# Constructed automatically by docker-compose from the variables above.
# Override here only if you connect to an external database.
# DATABASE_URL=postgresql+asyncpg://echogtfs:change_me_in_production@db:5432/echogtfs
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ---------- JWT ----------
# REQUIRED: Generate a secure secret key with: openssl rand -hex 32
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------- API docs (Swagger / ReDoc) ----------
# Keep false in production. Set to true only for local development.
DOCS_ENABLED=false

# ---------- CORS ----------
# Comma-separated list of allowed frontend origins.
# Example: https://app.example.com,https://www.example.com
# Leave empty to disallow all cross-origin requests (safe default when
# frontend and backend are served from the same origin via nginx).
CORS_ORIGINS=

# ---------- Rate-limiting ----------
# slowapi syntax: "<count>/<period>"  e.g. 10/minute, 3/second
LOGIN_RATE_LIMIT=10/minute

# ---------- First superuser (created on first startup if DB is empty) ----------
# REQUIRED: Set secure credentials for the initial admin account.
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_EMAIL=admin@localhost
FIRST_SUPERUSER_PASSWORD=

# ---------- Frontend ----------
FRONTEND_PORT=80
