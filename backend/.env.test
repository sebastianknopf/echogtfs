# Test environment configuration
# This file is used during test execution

# JWT Secret (required)
SECRET_KEY=test-secret-key-for-testing-only-not-for-production

# Database (not used in unit tests, but required by settings)
DATABASE_URL=postgresql+asyncpg://test:test@localhost:5432/test

# Server settings
HOST=localhost
PORT=8000
DEBUG=true

# API docs
DOCS_ENABLED=true

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate limiting
LOGIN_RATE_LIMIT=100/minute

# First superuser
FIRST_SUPERUSER=test_admin
FIRST_SUPERUSER_EMAIL=test@example.com
FIRST_SUPERUSER_PASSWORD=test_password
